{
  "functions": [
    {
      "source": "services/api",
      "codebase": "hhh-api",
      "runtime": "nodejs22",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"],
      "ignore": ["node_modules", ".git", "firebase-debug.log", "*.local", ".env", ".env.*"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8081 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true }
  }
}
