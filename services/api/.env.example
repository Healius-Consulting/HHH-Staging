PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
NODE_ENV=development
FIREBASE_PROJECT_ID=hhh-development
FIREBASE_STORAGE_BUCKET=hhh-development.firebasestorage.app
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
REQUIRE_APP_CHECK=false
REQUIRE_MFA=false

# HHH has one Curaleaf API key. In deployed Functions, configure it with:
# firebase functions:secrets:set CURALEAF_API_KEY
CURALEAF_BASE_URL=https://api.curaleaflaboratories.dev
CURALEAF_API_KEY=replace-with-the-single-hhh-api-key

# Pharmacy customer IDs/portal emails and Worldpay merchant credentials are
# stored per pharmacy in Google Secret Manager through the authenticated API.
# WORLDPAY_HPP_BASE_URL=https://try.access.worldpay.com
# WORLDPAY_VERIFY_BASE_URL=https://try.access.worldpay.com
