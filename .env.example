# Shared by the portal and independently hosted eligibility form.
VITE_API_BASE_URL=http://localhost:8080
VITE_ELIGIBILITY_FORM_URL=http://localhost:5174

# Development only. Never ship a static portal token in production.
VITE_PORTAL_ACCESS_TOKEN=replace-with-the-same-development-token

# API only. DATABASE_URL is optional for local development; without it the API
# uses in-memory seed data. Configure PostgreSQL for persistent staging/prod.
# DATABASE_URL=postgresql://user:password@localhost:5432/hhh
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Curaleaf Rocky — API service only. Never prefix these with VITE_ or expose
# them to the browser. Use each credential only for its permitted operation.
CURALEAF_BASE_URL=https://api.curaleaflaboratories.dev
CURALEAF_READ_API_KEY=replace-with-curaleaf-read-key
CURALEAF_WRITE_API_KEY=replace-with-curaleaf-write-key
