# Public browser configuration for the staff portal. These values identify the
# Firebase web app; they are not service-account credentials or integration keys.
VITE_APP_ENV=local
VITE_API_BASE_URL=http://127.0.0.1:5001/your-project/europe-west2/api
VITE_ELIGIBILITY_FORM_URL=http://localhost:5174
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
VITE_FIREBASE_APP_ID=replace-with-web-app-id
VITE_FIREBASE_APP_CHECK_SITE_KEY=replace-with-recaptcha-enterprise-site-key
VITE_REQUIRE_MFA=false

# Curaleaf, Worldpay and service-account secrets belong in Google Secret
# Manager/Firebase Functions configuration. Never add them as VITE_* values.
